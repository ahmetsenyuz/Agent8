@page
@model IndexModel
@{
    ViewData["Title"] = "Todo Items";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Todo Items</h1>
        <a asp-page="/Create" class="btn btn-primary">Create New</a>
    </div>

    @if (!Model.Todos.Any())
    {
        <div class="alert alert-info">
            <p>No todo items found. <a asp-page="/Create">Create the first one</a>.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Title</th>
                        <th>Description</th>
                        <th>Status</th>
                        <th>Created At</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var todo in Model.Todos)
                    {
                        <tr>
                            <td>@todo.Title</td>
                            <td>@(string.IsNullOrEmpty(todo.Description) ? "No description" : todo.Description)</td>
                            <td>
                                @if (todo.IsCompleted)
                                {
                                    <span class="badge bg-success">Completed</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">Incomplete</span>
                                }
                            </td>
                            <td>@todo.CreatedAt.ToStr("yyyy-MM-dd HH:mm")</td>
                            <td>
                                <form method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@todo.Id" />
                                    <button type="submit" name="action" value="toggle" class="btn btn-sm @(todo.IsCompleted ? "btn-outline-warning" : "btn-outline-success")">
                                        @(todo.IsCompleted ? "Mark Incomplete" : "Mark Complete")
                                    </button>
                                </form>
                                <form method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@todo.Id" />
                                    <button type="submit" name="action" value="delete" class="btn btn-sm btn-outline-danger" onclick="return confirm('Are you sure you want to delete this item?');">
                                        Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>